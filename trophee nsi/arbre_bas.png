slot_actuel = 0
def sauvegarder(slot):
    global niveau_max, argent, arme1_debloquee
    # Sécurité : on ne sauvegarde pas si le slot n'est pas défini (0)
    if slot == 0: 
        return
    try:
        with open(f"save{slot}.txt", "w") as f:
            f.write(f"{niveau_max}\n")
            f.write(f"{argent}\n")
            f.write(f"{int(arme1_debloquee)}\n")
        print(f"Sauvegarde réussie dans le slot {slot}")
    except Exception as e:
        print(f"Erreur lors de la sauvegarde : {e}")

def charger(slot):
    global niveau_max, argent, arme1_debloquee, slot_actuel
    slot_actuel = slot
    try:
        with open(f"save{slot}.txt", "r") as f:
            lignes = f.readlines()
            niveau_max = int(lignes[0].strip())
            argent = int(lignes[1].strip())
            arme1_debloquee = bool(int(lignes[2].strip()))
        print(f"Slot {slot} chargé : Niveau {niveau_max}, Argent {argent}")
    except:
        print(f"Pas de fichier save{slot}.txt, initialisation par défaut.")
        niveau_max = 1
        argent = 0
        arme1_debloquee = 0

    niveau_max = max(1, niveau_max)

def recuperer_infos_save(slot):
    try:
        with open(f"save{slot}.txt", "r") as f:
            lignes = f.readlines()
            if len(lignes) >= 3:
                niv = lignes[0].strip()
                arg = lignes[1].strip()
                etat_arme_shop = int(lignes[2].strip())

                nb_total = 1 + etat_arme_shop
                
                return {"niv": niv, "argent": arg, "nb": nb_total}
    except:
        return None
    return None

