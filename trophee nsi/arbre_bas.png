def button(color, txt, pos_x, pos_y, width, height, color_txt, font, around=0):
    """Crée un bouton et centre automatiquement le texte à l'intérieur."""
    # 1. Dessiner le rectangle de fond
    rect = pygame.draw.rect(surface_jeu, color, [int(pos_x*SCALE), int(pos_y*SCALE), int(width*SCALE), int(height*SCALE)])
    
    # 2. Rendre le texte
    txt_button = font.render(txt, True, color_txt)
    pos_txt = txt_button.get_rect()
    
    # 3. La magie : on dit à Pygame de centrer le texte par rapport au rectangle qu'on vient de dessiner !
    pos_txt.center = rect.center 
    surface_jeu.blit(txt_button, pos_txt)
    
    # 4. Le contour (optionnel)
    if around != 0:
        pygame.draw.rect(surface_jeu, color, [int(pos_x*SCALE), int(pos_y*SCALE), int(width*SCALE), int(height*SCALE)], around)
        
    return rect

def ennemi_colore(image, couleur):
    img = image.copy()
    img.fill(couleur, special_flags=pygame.BLEND_RGBA_MULT)
    return img

def calcul_camera(joueur, carte_actuelle):
    """
    Calcule la position de la caméra pour suivre le joueur.
    La caméra est centrée sur le joueur mais reste dans les limites de la carte.
    Retourne (cam_x, cam_y) en pixels.
    """
    cam_x = joueur["x"] - screen_width // 2
    cam_y = joueur["y"] - screen_height // 2

    largeur_carte = len(carte_actuelle[0]) * TAILLE_TUILE
    hauteur_carte = len(carte_actuelle) * TAILLE_TUILE

    # On bloque la caméra aux limites de la carte
    cam_x = max(0, min(cam_x, largeur_carte - screen_width))
    cam_y = max(0, min(cam_y, hauteur_carte - screen_height))

    return cam_x, cam_y

def creer_ennemi():
    global ennemis
    
    liste_disponible = types_gobelins[type_gobelin_actuel]
    # 1. Gestion des probabilités
    # On crée une liste contenant uniquement les poids : [60, 25, 10, 5]
    poids = [m["poids"] for m in liste_disponible]
    
    # Tirage au sort probabiliste
    config = random.choices(liste_disponible, weights=poids, k=1)[0]

    # 2. Positionnement
    # Trouver toutes les cases spawn (3)
    spawns = []
    for y_map, ligne in enumerate(carte_actuelle):
        for x_map, tuile in enumerate(ligne):
            if tuile == 3:
                spawns.append((x_map, y_map))

    # Choisir un spawn aléatoire
    if spawns:
        col, lig = random.choice(spawns)
        x = col * TAILLE_TUILE
        y = lig * TAILLE_TUILE
    else:
        x = 500
        y = 500

    # 3. Préparation de l'image (Scale et Couleur)
    # On part de l'image de base et on l'adapte à la taille définie dans le dictionnaire
    # Taille selon le config (utilise la taille du dictionnaire)
    taille_sprite = int(config["taille"] * SCALE)

    # Teinte selon le type ET la taille pour les différencier
    if config["type"] == "feu":
        if config["taille"] == 35:
            teinte = (255, 180, 100)   # orange clair = petit
        elif config["taille"] == 50:
            teinte = (255, 100, 50)    # orange vif = normal
        elif config["taille"] == 65:
            teinte = (220, 50, 50)     # rouge = grand
        else:
            teinte = (150, 0, 0)       # rouge foncé = chef
    else:
        teinte = (255, 255, 255)       # blanc par défaut
    
    frames_precalculees = {}
    for direction, liste_frames in frames_ennemi.items():
        frames_precalculees[direction] = []
        for frame in liste_frames:
            f = pygame.transform.smoothscale(frame, (taille_sprite, taille_sprite))
            f = ennemi_colore(f, teinte)
            frames_precalculees[direction].append(f)

    # On prend la frame "devant" comme base pour l'image stockée (non utilisée pour l'anim mais garde la cohérence)
    img_base = frames_ennemi["devant"][0].copy()
    img_base = pygame.transform.smoothscale(img_base, (taille_sprite, taille_sprite))
    img_finale = ennemi_colore(img_base, teinte)
    # Création du dictionnaire du ennemi "vivant"
    nouveau_ennemi = {
        "x": x,
        "y": y,
        "img": img_finale,
        "taille_sprite": taille_sprite,
        "teinte": teinte,
        "frames": frames_precalculees,
        "hp": config["hp"],
        "hp_max": config["hp"],
        "type": config["type"], # Futur : servira pour les faiblesses
        "score": config["score"],
        "argent": config["argent"],
        "vitesse": config["vitesse"], # On peut même varier la vitesse par type !
        "timer_anim": random.randint(0, 20),  # décalage pour que tous ne bougent pas pareil
        "frame_actuelle": 0,
        "timer_anim": 0,
        "direction": "devant",
        "timer_hit": 0,
        "taille_spawn": 0,   # pour l'effet spawn
        "en_spawn": True,

    }
    
    ennemis.append(nouveau_ennemi)


