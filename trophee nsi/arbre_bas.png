# La Carte (Matrice). 
# Pour un écran 1920x1080 avec des tuiles de 64, ça fait 30 colonnes et 17 lignes.
# Voici une mini-carte d'exemple (j'ai réduit pour que ce soit lisible, on la fera plus grande après)
def charger_ma_carte(nom_fichier):
    chemin_fichier = os.path.join(BASE_DIR, nom_fichier)
    
    if not os.path.exists(chemin_fichier):
        print(f"ALERTE : Le fichier {chemin_fichier} n'existe pas !")
        return [[1, 1, 1], [1, 0, 1], [1, 1, 1]]
    
    matrice = []
    with open(chemin_fichier, "r") as f:
        for ligne in f:
            ligne_propre = ligne.strip()
            if ligne_propre:
                # Séparation par virgule pour gérer les nombres ≥10
                matrice.append([int(n) for n in ligne_propre.split(",")])
    return matrice

